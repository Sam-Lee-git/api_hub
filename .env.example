# ── Database ─────────────────────────────────────────────────────────────────
# DB_DRIVER: "postgres" (default) or "sqlite" (no extra services needed)
DB_DRIVER=sqlite
SQLITE_PATH=./data/aiproxy.db

# PostgreSQL (used when DB_DRIVER=postgres)
DATABASE_URL=postgres://aiproxy:changeme@localhost:5432/aiproxy?sslmode=disable

# ── Cache ─────────────────────────────────────────────────────────────────────
# CACHE_DRIVER: "redis" (default) or "memory" (single-instance only)
CACHE_DRIVER=memory

# Redis (used when CACHE_DRIVER=redis)
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=<32-byte-random>
JWT_REFRESH_SECRET=<32-byte-different>

# ── AI Provider Keys ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
ALIBABA_API_KEY=sk-...

# ── Alipay ────────────────────────────────────────────────────────────────────
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://yourdomain.com/api/payment/alipay/notify

# ── WeChat Pay ────────────────────────────────────────────────────────────────
WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_API_V3_KEY=
WECHAT_CERT_SERIAL=
WECHAT_NOTIFY_URL=https://yourdomain.com/api/payment/wechat/notify

# ── Admin Seed ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<strong-password>

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENV=development
